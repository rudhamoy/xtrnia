// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String?
  fullName      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]

  @@index([createdAt])
}

model Competition {
  id        String   @id @default(cuid())
  name      String
  badge     String
  date      String

  image     String
  category  String
  minClass  Int
  maxClass  Int
  prizes    String   // JSON string array
  type      String   // "current" or "upcoming"
  status    String   @default("active") // "active" or "inactive"
  order     Int      @default(0)
  instructionVideo String? // YouTube link
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]

  @@index([type, order, createdAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Brochure {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String
  publicId  String
  isActive  Boolean  @default(false)
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Registration {
  id                    String   @id @default(cuid())
  institutionType       InstitutionType @default(SCHOOL)
  schoolName            String
  schoolAddress         String
  teacherName           String
  teacherPhone          String   @default("")
  participationOptions  Json
  totalAmount           String
  paymentStatus         PaymentStatus @default(PENDING)
  paymentGateway        PaymentGateway @default(RAZORPAY)
  paymentAmount         Int?
  paymentCurrency       String  @default("INR")
  paymentOrderId        String?
  paymentId             String?
  paymentPaidAt         DateTime?
  paymentError          String?
  userId                String?
  user                  User? @relation(fields: [userId], references: [id])
  competitionId         String?
  competition           Competition? @relation(fields: [competitionId], references: [id])
  createdAt             DateTime @default(now())

  @@index([userId, createdAt])
}

enum InstitutionType {
  SCHOOL
  COLLEGE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentGateway {
  RAZORPAY
}
